---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ListingTable from '../components/ListingTable.astro';
import AdSlot from '../components/AdSlot.astro';
import LeadForm from '../components/LeadForm.astro';
import {
  getPublishedMetros,
  groupByCity,
  lowestPrice,
  tentSizeBreakdown,
  bounceHousePriceRange,
  type Listing,
} from '../lib/listings';
import type { MetroMeta } from '../lib/metros';
import { breadcrumbJsonLd, itemListJsonLd } from '../lib/seo';

export function getStaticPaths() {
  return getPublishedMetros().map(({ meta, listings }) => ({
    params: { metro: meta.slug },
    props: { meta, listings },
  }));
}

interface Props {
  meta: MetroMeta;
  listings: Listing[];
}
const { meta, listings } = Astro.props;

const prices = listings.map(lowestPrice).filter((p): p is number => p != null);
const minPrice = prices.length ? Math.min(...prices) : null;
const maxPrice = prices.length ? Math.max(...prices) : null;

const cities = groupByCity(listings);
const multiCity = cities.length > 1;

const tentSizes = tentSizeBreakdown(listings);
const bounceHouse = bounceHousePriceRange(listings);
// tentSizes is already filtered to real WxH tent items, so it's a cleaner
// "tent starting price" than the site-wide minPrice above (which can surface
// a $1-2 line item like a sock or deposit add-on as the "lowest price").
const tentMin = tentSizes.length ? Math.min(...tentSizes.map((t) => t.low)) : null;

const title = `${meta.name} Rental Prices (${listings.length} Companies)`;
const description = `Real prices from ${listings.length} verified tent, table, and chair rental companies in ${meta.name} — actual dollar figures, not vague quotes.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: meta.name, href: `/${meta.slug}/` },
];
const jsonLd = [breadcrumbJsonLd(breadcrumbs), itemListJsonLd(listings, 'https://eventrentalcosts.com')];
---
<BaseLayout title={title} description={description} path={`/${meta.slug}/`} jsonLd={jsonLd}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Party &amp; Tent Rental Prices in {meta.name}</h1>

    <p class="intro">
      {meta.blurb} We list the {listings.length} local rental companies below that actually publish
      real pricing on their own websites — not vague "contact us for a quote" pages.
      {minPrice != null && maxPrice != null && (
        <> Starting prices we found range from about ${minPrice.toFixed(0)} to ${maxPrice.toFixed(0)}
        depending on the company and item, though most quote per-tent, per-table, or per-chair
        rather than a flat rate.</>
      )}
    </p>

    {multiCity ? (
      cities.map(({ city, listings: cityListings }, i) => (
        <section class="city-section">
          <h2 id={city.toLowerCase().replace(/\s+/g, '-')}>{city}, {meta.state}</h2>
          <ListingTable listings={cityListings} />
          {i === 0 && <AdSlot variant="in-content" />}
        </section>
      ))
    ) : (
      <>
        <ListingTable listings={listings} />
        <AdSlot variant="in-content" />
      </>
    )}

    {tentSizes.length > 0 && (
      <section class="size-breakdown">
        <h2>Tent rental cost by size in {meta.name}</h2>
        <p class="muted">
          Real starting prices pulled directly from local companies' own published rate sheets,
          broken out by tent size.
        </p>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Tent size</th><th>Starting price</th><th>Companies</th></tr>
            </thead>
            <tbody>
              {tentSizes.map((t) => (
                <tr>
                  <td>{t.size}</td>
                  <td>{t.low === t.high ? <>${t.low.toFixed(0)}</> : <>${t.low.toFixed(0)}–${t.high.toFixed(0)}</>}</td>
                  <td class="muted">{t.count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {bounceHouse && (
      <section class="bounce-house">
        <h2>Bounce house rental cost in {meta.name}</h2>
        <p>
          Real published bounce house pricing from {meta.name} rental companies runs from
          about ${bounceHouse.low.toFixed(0)} to ${bounceHouse.high.toFixed(0)}, based on
          {' '}{bounceHouse.count} published price point{bounceHouse.count === 1 ? '' : 's'}. Exact
          cost depends on the unit — combo units with a slide typically cost more than a
          standalone bounce house. See each company's listing for the full lineup.
        </p>
      </section>
    )}

    <section class="faq">
      <h2>Common questions about {meta.name} party rentals</h2>
      <div class="faq-item">
        <h3>How much does a tent rental cost in {meta.name}?</h3>
        <p>
          {tentMin != null ? (
            <>Based on real published pricing from local companies, tent rental starts around
            ${tentMin.toFixed(0)} and varies by size — see the size-by-size breakdown above.</>
          ) : (
            <>It depends on tent size, delivery distance, and whether setup is included — see the
            per-company pricing tables above for real published rates.</>
          )}
        </p>
      </div>
      {bounceHouse && (
        <div class="faq-item">
          <h3>How much does a bounce house rental cost in {meta.name}?</h3>
          <p>
            About ${bounceHouse.low.toFixed(0)}–${bounceHouse.high.toFixed(0)} based on real
            pricing published by local companies, with combo units (bounce plus slide) generally
            at the higher end. See the "Bounce house rental cost" section above.
          </p>
        </div>
      )}
      <div class="faq-item">
        <h3>How much does table and chair rental cost in {meta.name}?</h3>
        <p>
          Usually priced per-item rather than as a package — check the pricing table for each
          company above for their published per-table and per-chair rates.
        </p>
      </div>
      <div class="faq-item">
        <h3>Do {meta.name} rental companies charge for delivery?</h3>
        <p>
          It varies by company — some include delivery within a set radius, others charge a
          separate fee based on distance. Check the "Delivery" column in each table above, or open
          an individual listing for the exact policy where it's published.
        </p>
      </div>
      <div class="faq-item">
        <h3>Is party rental pricing higher on weekends?</h3>
        <p>
          Some companies apply a weekend or peak-season surcharge, especially during busy spring
          and fall wedding months. We note this per company where it's explicitly published — it's
          marked "Not published" rather than "No" when a company doesn't state a policy either way,
          since we don't guess.
        </p>
      </div>
      <div class="faq-item">
        <h3>How is this pricing data collected?</h3>
        <p>
          We scrape each rental company's own website directly and extract real dollar figures
          they've published — we never estimate or fabricate a price. See our
          <a href="/about/">methodology page</a> for the full process and last-checked dates.
        </p>
      </div>
    </section>

    <LeadForm metroName={meta.name} />
  </div>
</BaseLayout>

<style>
  .intro { max-width: 760px; margin-block: var(--space-4) var(--space-8); color: var(--color-text-muted); }
  .city-section { margin-bottom: var(--space-12); }
  .city-section h2 { margin-bottom: var(--space-4); }
  .size-breakdown, .bounce-house { margin-bottom: var(--space-12); max-width: 760px; }
  .size-breakdown .muted { color: var(--color-text-muted); margin-bottom: var(--space-3); }
  .size-breakdown .table-wrap {
    overflow-x: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .size-breakdown table { width: 100%; min-width: 360px; }
  .size-breakdown .muted { font-size: 0.82rem; }
  .bounce-house p { color: var(--color-text-muted); }
  .faq { margin-block: var(--space-12); max-width: 760px; }
  .faq-item { margin-bottom: var(--space-6); }
  .faq-item h3 { margin-bottom: var(--space-2); font-size: 1.05rem; }
  .faq-item p { color: var(--color-text-muted); margin: 0; }
</style>
