---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedMetros, tentSizeBreakdown, chairPriceMin } from '../lib/listings';
import { siteJsonLd } from '../lib/seo';

const metros = getPublishedMetros();
const totalListings = metros.reduce((sum, m) => sum + m.listings.length, 0);

const fmt = (n: number) => (n % 1 === 0 ? n.toFixed(0) : n.toFixed(2));

// One unified grid instead of per-state sub-grids — with only 1-3 metros in
// most states, a per-state grid produces lonely full-width single-card rows
// (audit finding U1). State now shows as a small tag on the card instead.
// Each card also gets a real price teaser (S5) — computed at build time from
// the same real data the metro page itself shows, not a separate claim.
const cards = metros
  .map(({ meta, listings }) => {
    const sizes = tentSizeBreakdown(listings);
    const cheapestSize = sizes.length
      ? sizes.reduce((min, s) => (s.low < min.low ? s : min), sizes[0])
      : null;
    const chairMin = chairPriceMin(listings);
    const teaser = cheapestSize
      ? `${cheapestSize.size} tents from $${fmt(cheapestSize.low)}`
      : chairMin != null
        ? `Chairs from $${fmt(chairMin)} each`
        : null;
    return { meta, listings, teaser };
  })
  .sort((a, b) => b.listings.length - a.listings.length);

const title = 'Real Party & Event Rental Prices, Compared';
const description = `Compare real, published prices from ${totalListings} verified tent, table, and chair rental companies across ${metros.length} US metro areas — actual numbers, not "call for a quote."`;
---
<BaseLayout title={title} description={description} path="/" jsonLd={siteJsonLd()}>
  <section class="hero">
    <div class="container">
      <h1>Real party &amp; event rental prices, compared</h1>
      <p class="lede">
        We collect actual published pricing directly from local tent, table, and chair rental
        companies — not vague "call for quote" estimates. {totalListings} verified companies across
        {metros.length} metro areas, and growing.
      </p>
    </div>
  </section>

  <section class="container">
    <h2>Choose your metro area</h2>
    <div class="metro-grid">
      {cards.map(({ meta, listings, teaser }) => (
        <a href={`/${meta.slug}/`} class="card metro-card">
          <span class="state-tag">{meta.state}</span>
          <h4>{meta.name}</h4>
          <p class="count">{listings.length} verified rental companies</p>
          {teaser && <p class="teaser">{teaser}</p>}
          <span class="metro-cta">View pricing &rarr;</span>
        </a>
      ))}
    </div>
  </section>

  <section class="container about-strip">
    <h2>Why prices, not just a directory</h2>
    <p>
      Google Maps shows you a business's name and phone number. It doesn't show you what a
      10x10 tent actually costs, whether delivery is included, or what a Saturday surcharge
      looks like. We scrape each company's own website for real, dated pricing — and we only
      list companies that actually publish real numbers. <a href="/about/">Read our methodology</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-12) var(--space-8);
    background: linear-gradient(180deg, rgba(181, 80, 47, 0.06), transparent);
  }
  .lede { font-size: 1.1rem; color: var(--color-text-muted); max-width: 660px; }
  .metro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .metro-card { padding: var(--space-6); position: relative; }
  .metro-card:hover { text-decoration: none; border-color: var(--color-primary); }
  .state-tag {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.15em 0.6em;
  }
  .metro-card h4 { margin-bottom: var(--space-2); font-size: 1.1rem; padding-right: var(--space-8); }
  .metro-card .count { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: var(--space-1); }
  .metro-card .teaser { color: var(--color-primary); font-size: 0.85rem; font-weight: 600; margin-bottom: var(--space-3); }
  .metro-cta { font-weight: 600; color: var(--color-primary); font-size: 0.9rem; }
  .about-strip { padding-bottom: var(--space-16); color: var(--color-text-muted); }
</style>
