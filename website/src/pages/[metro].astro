---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ListingTable from '../components/ListingTable.astro';
import AdSlot from '../components/AdSlot.astro';
import LeadForm from '../components/LeadForm.astro';
import {
  getPublishedMetros,
  groupByCity,
  chairPriceMin,
  tentSizeBreakdown,
  bounceHousePriceRange,
  photoBoothPriceRange,
  waterSlidePriceRange,
  type Listing,
} from '../lib/listings';
import type { MetroMeta } from '../lib/metros';
import { breadcrumbJsonLd, itemListJsonLd, faqPageJsonLd } from '../lib/seo';

export function getStaticPaths() {
  return getPublishedMetros().map(({ meta, listings }) => ({
    params: { metro: meta.slug },
    props: { meta, listings },
  }));
}

interface Props {
  meta: MetroMeta;
  listings: Listing[];
}
const { meta, listings } = Astro.props;

const cities = groupByCity(listings);
const multiCity = cities.length > 1;

const tentSizes = tentSizeBreakdown(listings);
const bounceHouse = bounceHousePriceRange(listings);
const photoBooth = photoBoothPriceRange(listings);
const waterSlide = waterSlidePriceRange(listings);
const tentMin = tentSizes.length ? Math.min(...tentSizes.map((t) => t.low)) : null;
const chairMin = chairPriceMin(listings);
// Wedding-size tents (20x40 and up, ~800+ sq ft) — targets the real
// "wedding tent rental cost" query (Easy KD, real volume per keyword-research.md).
const weddingTents = tentSizes.filter((t) => {
  const [w, h] = t.size.split('x').map(Number);
  return w * h >= 800;
});
const weddingMin = weddingTents.length ? Math.min(...weddingTents.map((t) => t.low)) : null;
const weddingMax = weddingTents.length ? Math.max(...weddingTents.map((t) => t.high)) : null;

const fmt = (n: number) => (n % 1 === 0 ? n.toFixed(0) : n.toFixed(2));

const title = `${meta.name} Rental Prices (${listings.length} Companies)`;
const description = `Real prices from ${listings.length} verified tent, table, and chair rental companies in ${meta.name} — actual dollar figures, not vague quotes.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: meta.name, href: `/${meta.slug}/` },
];

// FAQ content lives in this one array — the visible HTML and the FAQPage
// JSON-LD both render from it, so they can never drift apart. Google dropped
// visual FAQ rich results, but FAQPage markup measurably lifts citations in
// AI Overviews/ChatGPT/Perplexity (see Fable-5-analysis.md §4), which is the
// channel this site's llms.txt/robots.txt strategy already targets.
const faqs: { q: string; a: string }[] = [];
if (tentMin != null) {
  faqs.push({
    q: `How much does a tent rental cost in ${meta.name}?`,
    a: `Based on real published pricing from local companies, tent rental starts around $${fmt(tentMin)} and varies by size — see the size-by-size breakdown above.`,
  });
} else {
  faqs.push({
    q: `How much does a tent rental cost in ${meta.name}?`,
    a: `It depends on tent size, delivery distance, and whether setup is included — see the per-company pricing tables above for real published rates.`,
  });
}
if (weddingMin != null && weddingMax != null && weddingMax > weddingMin) {
  faqs.push({
    q: `How much does a wedding tent rental cost in ${meta.name}?`,
    a: `Larger tents suited to weddings (20x40 and up) run about $${fmt(weddingMin)}–$${fmt(weddingMax)} in ${meta.name}, based on real rates published by local companies. Final cost depends on size, sidewalls, and delivery.`,
  });
}
if (bounceHouse) {
  faqs.push({
    q: `How much does a bounce house rental cost in ${meta.name}?`,
    a: `About $${fmt(bounceHouse.low)}–$${fmt(bounceHouse.high)} based on real pricing published by local companies, with combo units (bounce plus slide) generally at the higher end. See the "Bounce house rental cost" section above.`,
  });
}
if (photoBooth) {
  faqs.push({
    q: `How much does a photo booth rental cost in ${meta.name}?`,
    a: `Real published photo booth pricing in ${meta.name} runs about $${fmt(photoBooth.low)}–$${fmt(photoBooth.high)}, based on ${photoBooth.count} published price point${photoBooth.count === 1 ? '' : 's'}. 360 booths and mirror booths typically price above a standard enclosed booth.`,
  });
}
if (waterSlide) {
  faqs.push({
    q: `How much does a water slide rental cost in ${meta.name}?`,
    a: `About $${fmt(waterSlide.low)}–$${fmt(waterSlide.high)} based on real published rates from local companies — taller dual-lane slides and slide/pool combos sit at the higher end.`,
  });
}
faqs.push(
  {
    q: `How much does table and chair rental cost in ${meta.name}?`,
    a: `Usually priced per-item rather than as a package${chairMin != null ? ` — folding chairs start around $${fmt(chairMin)} each` : ''}. Check the pricing table for each company above for their published per-table and per-chair rates.`,
  },
  {
    q: `Do ${meta.name} rental companies charge for delivery?`,
    a: `It varies by company — some include delivery within a set radius, others charge a separate fee based on distance. Check the "Delivery" column in each table above, or open an individual listing for the exact policy where it's published.`,
  },
  {
    q: `Is party rental pricing higher on weekends?`,
    a: `Some companies apply a weekend or peak-season surcharge, especially during busy spring and fall wedding months. We note this per company where it's explicitly published — it's marked "Not published" rather than "No" when a company doesn't state a policy either way, since we don't guess.`,
  },
  {
    q: `How is this pricing data collected?`,
    a: `We scrape each rental company's own website directly and extract real dollar figures they've published — we never estimate or fabricate a price. See our methodology page for the full process and last-checked dates.`,
  },
);

const jsonLd = [
  breadcrumbJsonLd(breadcrumbs),
  itemListJsonLd(listings, 'https://eventrentalcosts.com'),
  faqPageJsonLd(faqs),
];
---
<BaseLayout title={title} description={description} path={`/${meta.slug}/`} jsonLd={jsonLd}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Party &amp; Tent Rental Prices in {meta.name}</h1>

    <p class="intro">
      {meta.blurb} We list the {listings.length} local rental companies below that actually publish
      real pricing on their own websites — not vague "contact us for a quote" pages.
      {(chairMin != null || tentMin != null) && (
        <> Real examples from their published rates:
        {chairMin != null && <> folding chairs from ${fmt(chairMin)} each</>}
        {chairMin != null && tentMin != null && <>,</>}
        {tentMin != null && <> tents from ${fmt(tentMin)}</>}
        &nbsp;— most companies quote per-item rather than a flat rate.</>
      )}
    </p>

    {multiCity ? (
      cities.map(({ city, listings: cityListings }, i) => (
        <section class="city-section">
          <h2 id={city.toLowerCase().replace(/\s+/g, '-')}>{city}, {meta.state}</h2>
          <ListingTable listings={cityListings} />
          {i === 0 && <AdSlot variant="in-content" />}
        </section>
      ))
    ) : (
      <>
        <ListingTable listings={listings} />
        <AdSlot variant="in-content" />
      </>
    )}

    {tentSizes.length > 0 && (
      <section class="size-breakdown">
        <h2>Tent rental cost by size in {meta.name}</h2>
        <p class="muted">
          Real starting prices pulled directly from local companies' own published rate sheets,
          broken out by tent size.
        </p>
        <div class="table-wrap">
          <table>
            <thead>
              <tr><th>Tent size</th><th>Starting price</th><th>Companies</th></tr>
            </thead>
            <tbody>
              {tentSizes.map((t) => (
                <tr>
                  <td>{t.size}</td>
                  <td>{t.low === t.high ? <>${t.low.toFixed(0)}</> : <>${t.low.toFixed(0)}–${t.high.toFixed(0)}</>}</td>
                  <td class="muted">{t.count}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {bounceHouse && (
      <section class="bounce-house">
        <h2>Bounce house rental cost in {meta.name}</h2>
        <p>
          Real published bounce house pricing from {meta.name} rental companies runs from
          about ${bounceHouse.low.toFixed(0)} to ${bounceHouse.high.toFixed(0)}, based on
          {' '}{bounceHouse.count} published price point{bounceHouse.count === 1 ? '' : 's'}. Exact
          cost depends on the unit — combo units with a slide typically cost more than a
          standalone bounce house. See each company's listing for the full lineup.
        </p>
      </section>
    )}

    {photoBooth && (
      <section class="bounce-house">
        <h2>Photo booth rental cost in {meta.name}</h2>
        <p>
          Real published photo booth pricing from {meta.name} companies runs from
          about ${photoBooth.low.toFixed(0)} to ${photoBooth.high.toFixed(0)}, based on
          {' '}{photoBooth.count} published price point{photoBooth.count === 1 ? '' : 's'}.
          360 booths and mirror booths typically price above a standard enclosed booth;
          most quote per event or per hour.
        </p>
      </section>
    )}

    {waterSlide && (
      <section class="bounce-house">
        <h2>Water slide rental cost in {meta.name}</h2>
        <p>
          Real published water slide pricing from {meta.name} companies runs from
          about ${waterSlide.low.toFixed(0)} to ${waterSlide.high.toFixed(0)}, based on
          {' '}{waterSlide.count} published price point{waterSlide.count === 1 ? '' : 's'}.
          Taller dual-lane slides and slide/pool combos sit at the higher end.
        </p>
      </section>
    )}

    <section class="faq">
      <h2>Common questions about {meta.name} party rentals</h2>
      {faqs.map((faq) => (
        <div class="faq-item">
          <h3>{faq.q}</h3>
          <p>
            {faq.a.includes('methodology page') ? (
              <>We scrape each rental company's own website directly and extract real dollar figures
              they've published — we never estimate or fabricate a price. See our
              <a href="/about/">methodology page</a> for the full process and last-checked dates.</>
            ) : (
              faq.a
            )}
          </p>
        </div>
      ))}
    </section>

    <LeadForm metroName={meta.name} />
  </div>
</BaseLayout>

<style>
  .intro { max-width: 760px; margin-block: var(--space-4) var(--space-8); color: var(--color-text-muted); }
  .city-section { margin-bottom: var(--space-12); }
  .city-section h2 { margin-bottom: var(--space-4); }
  .size-breakdown, .bounce-house { margin-bottom: var(--space-12); max-width: 760px; }
  .size-breakdown .muted { color: var(--color-text-muted); margin-bottom: var(--space-3); }
  .size-breakdown .table-wrap {
    overflow-x: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .size-breakdown table { width: 100%; min-width: 360px; }
  .size-breakdown .muted { font-size: 0.82rem; }
  .bounce-house p { color: var(--color-text-muted); }
  .faq { margin-block: var(--space-12); max-width: 760px; }
  .faq-item { margin-bottom: var(--space-6); }
  .faq-item h3 { margin-bottom: var(--space-2); font-size: 1.05rem; }
  .faq-item p { color: var(--color-text-muted); margin: 0; }
</style>
