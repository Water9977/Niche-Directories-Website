---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ListingTable from '../../components/ListingTable.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getMetroSuburbListingsByCity, getMetroSuburbListings } from '../../lib/listings';
import { breadcrumbJsonLd, itemListJsonLd } from '../../lib/seo';

const grouped = getMetroSuburbListingsByCity();
const allListings = getMetroSuburbListings();
const townNames = Object.keys(grouped);

const title = `Party & Tent Rental Prices in the Charlotte Metro Suburbs (${allListings.length} Companies)`;
const description = `Compare real published rental prices from verified party, tent, table, and chair rental companies in ${townNames.join(', ')} — the towns surrounding Charlotte, NC.`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Charlotte Metro Suburbs', href: '/charlotte-metro-nc/' },
];

const jsonLd = [
  breadcrumbJsonLd(breadcrumbs),
  itemListJsonLd(allListings, 'https://eventrentalcosts.com'),
];
---
<BaseLayout title={title} description={description} path="/charlotte-metro-nc/" jsonLd={jsonLd}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Party &amp; Tent Rental Prices in the Charlotte Metro Suburbs</h1>

    <p class="intro">
      The towns ringing Charlotte — Concord, Huntersville, Mooresville, Indian Trail, and Monroe —
      each have too few verified rental companies with real published pricing to justify a
      standalone page yet, so we've combined them here rather than publish thin, mostly-empty
      pages. As we verify more companies in each town, they may graduate to their own page. For
      the fullest comparison, also check our <a href="/charlotte-nc/">Charlotte, NC page</a>,
      which has {allListings.length > 0 ? 'more' : ''} listings and typically the shortest delivery
      distance for events near the city center.
    </p>

    {townNames.map((town, i) => (
      <section class="town-section">
        <h2 id={town.toLowerCase().replace(/\s+/g, '-')}>{town}, NC</h2>
        <ListingTable listings={grouped[town]} />
        {i === 1 && <AdSlot variant="in-content" />}
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .intro { max-width: 760px; margin-block: var(--space-4) var(--space-8); color: var(--color-text-muted); }
  .town-section { margin-bottom: var(--space-12); }
  .town-section h2 { margin-bottom: var(--space-4); }
</style>
