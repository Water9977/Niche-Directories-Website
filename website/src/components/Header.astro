---
import { getPublishedMetros } from '../lib/listings';
// Show the first few metros in the nav; the homepage lists all of them.
const metros = getPublishedMetros().slice(0, 3);
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">EventRentalCosts<span class="brand-dot">.com</span></a>
    <nav class="nav" aria-label="Main navigation">
      {metros.map((m) => <a href={`/${m.meta.slug}/`}>{m.meta.name}</a>)}
      <a href="/about/">About</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-4);
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .brand {
    font-weight: 800;
    font-size: 1.15rem;
    color: var(--color-text);
  }
  .brand:hover { text-decoration: none; color: var(--color-primary); }
  .brand-dot { color: var(--color-text-muted); font-weight: 500; }
  .nav {
    display: flex;
    gap: var(--space-6);
    font-size: 0.92rem;
    font-weight: 600;
  }
  .nav a { color: var(--color-text); }
  .nav a:hover { color: var(--color-primary); }
</style>
