---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ListingTable from '../../components/ListingTable.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCharlotteListings, lowestPrice } from '../../lib/listings';
import { breadcrumbJsonLd, itemListJsonLd } from '../../lib/seo';

const listings = getCharlotteListings();
const prices = listings.map(lowestPrice).filter((p): p is number => p != null);
const minPrice = prices.length ? Math.min(...prices) : null;
const maxPrice = prices.length ? Math.max(...prices) : null;

const title = `Party & Tent Rental Prices in Charlotte, NC (${listings.length} Companies Compared)`;
const description = `Compare real published prices from ${listings.length} verified party, tent, table, and chair rental companies in Charlotte, NC. ${minPrice != null ? `Prices start around $${minPrice.toFixed(0)}.` : ''}`;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Charlotte, NC', href: '/charlotte-nc/' },
];

const jsonLd = [
  breadcrumbJsonLd(breadcrumbs),
  itemListJsonLd(listings, 'https://eventrentalcosts.com'),
];
---
<BaseLayout title={title} description={description} path="/charlotte-nc/" jsonLd={jsonLd}>
  <div class="container">
    <Breadcrumbs items={breadcrumbs} />
    <h1>Party &amp; Tent Rental Prices in Charlotte, NC</h1>

    <p class="intro">
      Charlotte's wedding and event market moves roughly $508 million a year across an
      estimated 13,900+ weddings, on top of corporate events, festivals, and backyard parties
      spread from NoDa to South End to Ballantyne. That volume supports {listings.length} local
      rental companies below who actually publish real pricing on their own websites — not
      vague "contact us for a quote" pages. {minPrice != null && maxPrice != null && (
        <>Starting prices we found range from about ${minPrice.toFixed(0)} to ${maxPrice.toFixed(0)}
        depending on the company and item, though most quote per-tent, per-table, or per-chair
        rather than a flat rate.</>
      )}
    </p>

    <ListingTable listings={listings} />

    <AdSlot variant="in-content" />

    <section class="faq">
      <h2>Common questions about Charlotte party rentals</h2>
      <div class="faq-item">
        <h3>Do Charlotte tent rental companies charge for delivery?</h3>
        <p>
          It varies by company — some Charlotte-area rental businesses include delivery within
          a set radius, others charge a separate delivery fee based on distance. Check the
          "Delivery" column above for each company, or view the individual listing for the exact
          policy where it's published.
        </p>
      </div>
      <div class="faq-item">
        <h3>Is Charlotte party rental pricing higher on weekends?</h3>
        <p>
          Some companies apply a weekend or peak-season surcharge, especially during Charlotte's
          busy spring and fall wedding months. We note this per company where it's explicitly
          published on their site — it's marked "Not published" rather than "No" when a company
          doesn't state a policy either way, since we don't guess.
        </p>
      </div>
      <div class="faq-item">
        <h3>How is this pricing data collected?</h3>
        <p>
          We scrape each rental company's own website directly and extract real dollar figures
          they've published — we never estimate or fabricate a price. See our
          <a href="/about/">methodology page</a> for the full process and last-checked dates.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .intro { max-width: 760px; margin-block: var(--space-4) var(--space-8); color: var(--color-text-muted); }
  .faq { margin-block: var(--space-12); max-width: 760px; }
  .faq-item { margin-bottom: var(--space-6); }
  .faq-item h3 { margin-bottom: var(--space-2); font-size: 1.05rem; }
  .faq-item p { color: var(--color-text-muted); margin: 0; }
</style>
