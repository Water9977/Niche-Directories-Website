---
// Reserved ad space only — no ad network wired up yet (site has zero traffic;
// applying to AdSense/Mediavine is a later-stage decision, see architecture.md).
// Space is reserved via CSS min-height now so turning ads on later never causes
// layout shift or requires a redesign. Per research: never reserve space with
// JS, always CSS. Never render this on the quote-request flow — a clicked ad
// there is a lost lead, not incremental revenue.
export interface Props {
  variant?: 'in-content' | 'anchor';
}
const { variant = 'in-content' } = Astro.props;
---

{/* The visible dashed "Ad space reserved" boxes read as broken scaffolding
    to visitors (and to businesses considering a featured listing) — audit
    finding B6 in Fable-5-analysis.md. The in-content slot keeps its reserved
    height invisibly so flipping ads on later still causes no layout shift;
    the mobile anchor variant is not rendered at all until an ad network is
    live, because permanently pinning ~50px of empty space to every mobile
    viewport costs real UX for zero revenue today. */}
{variant === 'in-content' && <div class="ad-slot ad-slot--in-content" aria-hidden="true" />}

<style>
  .ad-slot--in-content {
    width: 100%;
    max-width: 336px;
    min-height: 280px;
    background: none;
    border: none;
  }
</style>
